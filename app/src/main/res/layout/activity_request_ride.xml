<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:attr/windowBackground"
    android:padding="20dp"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Título -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Solicitar Paseo 🐶"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="?attr/colorPrimary"
            android:gravity="center"
            android:layout_marginBottom="20dp"
            tools:ignore="HardcodedText" />

        <!-- Seleccionar mascota -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Seleccionar mascota"
            android:textColor="?attr/colorOnBackground"
            android:layout_marginBottom="5dp"
            tools:ignore="HardcodedText" />

        <Spinner
            android:id="@+id/spMascotas"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="15dp"
            android:minHeight="48dp" />

        <!-- Fecha -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Fecha"
            android:textColor="?attr/colorOnBackground"
            android:layout_marginBottom="5dp"
            tools:ignore="HardcodedText" />

        <EditText
            android:id="@+id/etFecha"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="15dp"
            android:backgroundTint="?attr/colorSecondary"
            android:focusable="false"
            android:hint="Seleccionar fecha"
            android:minHeight="48dp"
            tools:ignore="HardcodedText,VisualLintTextFieldSize" />

        <!-- Hora -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Hora"
            android:textColor="?attr/colorOnBackground"
            android:layout_marginBottom="5dp"
            tools:ignore="HardcodedText" />

        <EditText
            android:id="@+id/etHora"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="15dp"
            android:backgroundTint="?attr/colorSecondary"
            android:focusable="false"
            android:hint="Seleccionar hora"
            android:minHeight="48dp"
            tools:ignore="HardcodedText,VisualLintTextFieldSize" />

        <!-- Dirección -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Dirección"
            android:textColor="?attr/colorOnBackground"
            android:layout_marginBottom="5dp"
            tools:ignore="HardcodedText" />

        <EditText
            android:id="@+id/etDireccionPaseo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            android:autofillHints=""
            android:backgroundTint="?attr/colorSecondary"
            android:hint="Ingrese dirección"
            android:minHeight="48dp"
            tools:ignore="HardcodedText" />

        <!-- Mapa -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Ubicación en el mapa"
            android:textColor="?attr/colorOnBackground"
            android:layout_marginBottom="5dp"
            tools:ignore="HardcodedText" />

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:background="?attr/colorSecondaryContainer"
            android:layout_marginBottom="20dp">

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@drawable/mapa_ejemplo"
                android:scaleType="centerCrop"
                android:contentDescription="Mapa de ubicación"
                tools:ignore="HardcodedText" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Mapa (seleccionar ubicación)"
                android:textColor="?attr/colorOnSecondaryContainer"
                android:layout_gravity="center"
                tools:ignore="HardcodedText" />

        </FrameLayout>

        <!-- Botón -->
        <Button
            android:id="@+id/btnConfirmarPaseo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:backgroundTint="?attr/colorPrimary"
            android:text="Confirmar Paseo"
            android:textColor="?attr/colorOnPrimary"
            tools:ignore="HardcodedText" />

    </LinearLayout>

</ScrollView>
