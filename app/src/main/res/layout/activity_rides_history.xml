<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?android:attr/windowBackground"
    android:padding="16dp">

    <!-- Título -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="10dp"
        android:gravity="center"
        android:text="Historial de Paseos 📋"
        android:textColor="?attr/colorPrimary"
        android:textSize="24sp"
        android:textStyle="bold"
        tools:ignore="HardcodedText" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:id="@+id/containerUltimoPaseo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            android:background="?attr/colorSecondaryContainer"
            android:orientation="vertical"
            android:padding="12dp">

            <TextView
                android:id="@+id/tvMascotaHistorial"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🐶 Mascota"
                android:textColor="#1565C0"
                android:textStyle="bold"
                tools:ignore="HardcodedText" />

            <TextView
                android:id="@+id/tvFechaHistorial"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📅 Fecha"
                android:textColor="?attr/colorOnSecondaryContainer"
                tools:ignore="HardcodedText" />

            <TextView
                android:id="@+id/tvHoraHistorial"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⏰ Hora"
                android:textColor="?attr/colorOnSecondaryContainer"
                tools:ignore="HardcodedText" />

            <TextView
                android:id="@+id/tvDireccionHistorial"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📍 Dirección"
                android:textColor="?attr/colorOnSecondaryContainer"
                tools:ignore="HardcodedText" />

            <TextView
                android:id="@+id/tvUsuarioHistorial"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="👨‍ Paseador"
                android:textColor="?attr/colorOnSecondaryContainer"
                tools:ignore="HardcodedText" />

            <TextView
                android:id="@+id/tvEstadoHistorial"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Estado: Pendiente"
                android:textColor="?attr/colorOnSecondaryContainer"
                tools:ignore="HardcodedText" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="8dp">

                <Button
                    android:id="@+id/btnVerDetalle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:backgroundTint="?attr/colorPrimary"
                    android:text="Ver detalle"
                    android:textColor="?attr/colorOnPrimary"
                    tools:ignore="HardcodedText" />

                <Button
                    android:id="@+id/btnContactarse"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="Contactarse"
                    tools:ignore="HardcodedText" />

            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!-- Volver -->
    <TextView
        android:id="@+id/tvVolverHistorial"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:clickable="true"
        android:focusable="true"
        android:minHeight="48dp"
        android:text="◀ Volver"
        android:textColor="?attr/colorPrimary"
        tools:ignore="HardcodedText" />

</LinearLayout>
